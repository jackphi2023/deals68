{
  "name": "deals68-production-full-beta",
  "version": "2.0.2-ui-match",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "seed": "node scripts/seed.mjs",
    "seed:businesses": "node scripts/seed-businesses.mjs",
    "seed:investors": "node scripts/seed-investors.mjs",
    "check:routes": "node scripts/check-routes.mjs",
    "extract:reference": "node scripts/extract-reference-css.mjs",
    "visual:businesses": "node scripts/visual-diff-businesses.mjs",
    "visual:businesses:local": "npm run build && (npm run preview -- --host 127.0.0.1 > /tmp/deals68-preview.log 2>&1 & echo $! > /tmp/deals68-preview.pid) && sleep 3 && npm run visual:businesses; kill $(cat /tmp/deals68-preview.pid)"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.45.4",
    "@vitejs/plugin-react": "4.3.4",
    "lucide-react": "0.468.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "6.30.1",
    "typescript": "5.6.3",
    "vite": "5.4.11"
  },
  "devDependencies": {
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "node-html-parser": "^6.1.13",
    "@playwright/test": "^1.49.0",
    "pixelmatch": "^6.0.0",
    "pngjs": "^7.0.0"
  }
}
