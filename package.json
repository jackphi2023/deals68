{
  "name": "deals68-production-full-beta",
  "version": "2.0.2-ui-match",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "seed": "node scripts/seed.mjs",
    "seed:businesses": "node scripts/seed-businesses.mjs",
    "seed:investors": "node scripts/seed-investors.mjs",
    "check:routes": "node scripts/check-routes.mjs",
    "extract:reference": "node scripts/extract-reference-css.mjs",
    "visual:businesses": "node scripts/visual-diff-businesses.mjs",
    "visual:businesses:local": "npm run build && (npm run preview -- --host 127.0.0.1 > /tmp/deals68-preview.log 2>&1 & echo $! > /tmp/deals68-preview.pid) && sleep 3 && npm run visual:businesses; kill $(cat /tmp/deals68-preview.pid)",
    "visual:routes": "node scripts/visual-diff-routes.mjs",
    "visual:pilots": "npm run build && (npm run preview -- --host 127.0.0.1 > /tmp/deals68-preview.log 2>&1 & echo $! > /tmp/deals68-preview.pid) && sleep 3 && npm run visual:routes; kill $(cat /tmp/deals68-preview.pid)",
    "visual:home": "D68_VISUAL_ROUTES=/ node scripts/visual-diff-routes.mjs",
    "test:e2e": "playwright test --config=playwright.config.ts",
    "test:e2e:public": "D68_TEST_MODE=public playwright test tests/e2e/00-public-smoke.spec.ts tests/e2e/01-pricing-valuation.spec.ts tests/e2e/04-public-profile-rules.spec.ts --config=playwright.config.ts",
    "test:e2e:auth": "D68_TEST_MODE=auth playwright test tests/e2e/02-register-business.spec.ts tests/e2e/03-register-investor.spec.ts tests/e2e/05-dashboard-admin-workflows.spec.ts --config=playwright.config.ts",
    "test:all": "npm run build && npm run test:e2e",
    "test:report": "node scripts/deals68-print-latest-report.mjs",
    "qa:release": "npm run build && node scripts/deals68-release-qa-check.mjs && npm run qa:packages",
    "qa:release:full": "npm run qa:release && npm run test:e2e:public",
    "postbuild": "node scripts/generate-sitemap.mjs dist",
    "qa:packages": "node scripts/deals68-package-checks.mjs",
    "qa:css": "node scripts/deals68-css-architecture-check.mjs",
    "qa:migrations": "node scripts/deals68-migration-state-check.mjs",
    "qa:fix-series": "node scripts/deals68-ui-business-fixes-v1-contract-check.mjs",
    "qa:asset-valuation": "node scripts/deals68-asset-valuation-v1-check.mjs",
    "qa:business-report-ui": "node scripts/deals68-business-report-ui-check.mjs",
    "qa:admin-reports": "node scripts/deals68-admin-reports-phase4-check.mjs",
    "qa:business-report-phase5": "node scripts/deals68-business-report-phase5-check.mjs",
    "qa:business-report-phase6": "node scripts/deals68-business-report-phase6-check.mjs",
    "qa:investor-plans": "node scripts/deals68-investor-plan-entitlements-check.mjs",
    "qa:investor-register-plans": "node scripts/deals68-investor-register-plans-phase2-check.mjs",
    "qa:investor-pricing": "node scripts/deals68-investor-pricing-phase3-check.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.45.4",
    "@vitejs/plugin-react": "4.3.4",
    "lucide-react": "0.468.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-router-dom": "6.30.1",
    "typescript": "5.6.3",
    "vite": "5.4.11"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@playwright/test": "^1.49.0",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "node-html-parser": "^6.1.13",
    "pixelmatch": "^7.0.0",
    "pngjs": "^7.0.0"
  }
}
